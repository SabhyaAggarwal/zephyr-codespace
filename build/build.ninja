  COMMAND = cd /workspaces/zephyr-codespace/build/zephyr/cmake/reports && /usr/bin/cmake --regenerate-during-build -S/workspaces/zephyr-codespace/app -B/workspaces/zephyr-codespace/build
  DESC = Running CMake to regenerate build system...
  pool = console
  restat = 1

build zephyr/cmake/reports/rebuild_cache: phony zephyr/cmake/reports/CMakeFiles/rebuild_cache.util


